    {
      "name": "4. Verify JSESSIONID cookie is set",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const jsessionId = pm.cookies.get('JSESSIONID');",
              "",
              "pm.test('JSESSIONID cookie exists', function () {",
              "  pm.expect(jsessionId, 'JSESSIONID').to.not.be.undefined;",
              "  pm.expect(jsessionId, 'JSESSIONID').to.not.equal('');",
              "});",
              "",
              "if (jsessionId) {",
              "  pm.collectionVariables.set('jsessionId', jsessionId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/user/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "me"
          ]
        }
      },
      "response": []
