    {
      "name": "6. Delete JSESSIONID cookie",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const jar = pm.cookies.jar();",
              "jar.unset(pm.collectionVariables.get('baseUrl'), 'JSESSIONID', function (error) {",
              "  if (error) {",
              "    console.warn('Unable to delete JSESSIONID automatically:', error);",
              "  }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('JSESSIONID cookie removed from Postman jar', function () {",
              "  pm.expect(pm.cookies.get('JSESSIONID')).to.be.undefined;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/login",
