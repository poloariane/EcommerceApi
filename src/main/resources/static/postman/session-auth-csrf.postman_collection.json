{
  "info": {
    "_postman_id": "5ce1d749-8d7f-4a6e-bd33-20d80e6c6a45",
    "name": "MyShop-Pay Session Auth and CSRF Tests",
    "description": "Task 8 collection for testing CSRF login, JSESSIONID cookie handling, protected order creation, and 401 behavior after removing the session cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. GET /login - capture CSRF token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('GET /login succeeds', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
              "});",
              "",
              "const html = pm.response.text();",
              "const tokenMatch = html.match(/name=[\"']_csrf[\"'][^>]*value=[\"']([^\"']+)[\"']/i) || html.match(/value=[\"']([^\"']+)[\"'][^>]*name=[\"']_csrf[\"']/i);",
              "const metaMatch = html.match(/<meta[^>]+name=[\"']_csrf[\"'][^>]+content=[\"']([^\"']+)[\"']/i);",
              "const csrfToken = tokenMatch && tokenMatch[1] ? tokenMatch[1] : metaMatch && metaMatch[1] ? metaMatch[1] : '';",
              "",
              "pm.test('CSRF token is present in login response', function () {",
              "  pm.expect(csrfToken, 'CSRF token').to.not.equal('');",
              "});",
              "",
              "if (csrfToken) {",
              "  pm.collectionVariables.set('csrfToken', csrfToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
